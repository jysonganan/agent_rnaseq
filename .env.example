# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development           # development | production
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (dev): sqlite:///./agent_rnaseq.db
# PostgreSQL (prod): postgresql+psycopg2://user:pass@host:5432/agent_rnaseq
DATABASE_URL=sqlite:///./agent_rnaseq.db

# ── API auth ──────────────────────────────────────────────────────────────────
# Bootstrap API key for admin operations (issue first real key via POST /api-keys)
API_KEY_BOOTSTRAP=change-me-before-use

# ── LLM (OpenAI Agents SDK) ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Output storage ────────────────────────────────────────────────────────────
OUTPUT_ROOT=/tmp/agent_rnaseq   # Local artifact root (overridden by S3 in prod)

# ── Redis (WebSocket log streaming) ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AWS (optional — only needed for S3/Batch execution) ───────────────────────
# Prefer IAM roles in production; set these only for local dev overrides.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
S3_ARTIFACT_BUCKET=             # e.g. my-rnaseq-artifacts
AWS_BATCH_JOB_QUEUE=            # e.g. arn:aws:batch:us-east-1:123456789012:job-queue/rnaseq
AWS_BATCH_JOB_DEFINITION=       # e.g. arn:aws:batch:us-east-1:123456789012:job-definition/rnaseq-worker
AWS_ENDPOINT_URL=               # e.g. http://localhost:4566 for LocalStack (dev only; leave empty for real AWS)
