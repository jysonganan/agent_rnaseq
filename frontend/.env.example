# FastAPI backend base URL (dev: local server, prod: leave empty for same-origin)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Streamlit visualization server URL
NEXT_PUBLIC_STREAMLIT_URL=http://localhost:8501

# Set to "1" to enable next build static export (used by `npm run build`)
# Do not set this in development — the dev server does not export
NEXT_EXPORT=1

# Set to "true" to use Mock Service Worker instead of real API (dev/test only)
NEXT_PUBLIC_USE_MOCK_API=false
