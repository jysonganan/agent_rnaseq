// RNA-seq Agent Pipeline — Nextflow configuration
// Profiles: local (default), awsbatch

nextflow.enable.dsl = 2

// ── Default parameters ────────────────────────────────────────────────────────
params {
    help            = false
    workflow        = 'qc'
    output_dir      = './results'
    sample_id       = 'sample'
    fastq_r1        = null
    fastq_r2        = null
    genome_dir      = null
    gtf_path        = null
    threads         = 8
    // AWS Batch overrides (used by awsbatch profile)
    aws_batch_queue = ''
    s3_work_dir     = 's3://nextflow-work/'
    aws_region      = 'us-east-1'
}

// ── Profiles ──────────────────────────────────────────────────────────────────
profiles {

    local {
        process {
            executor = 'local'
            cpus     = 4
            memory   = '16 GB'
        }
        workDir = '/tmp/nextflow_work'
    }

    awsbatch {
        process {
            executor = 'awsbatch'
            queue    = params.aws_batch_queue
            cpus     = 8
            memory   = '32 GB'
        }
        aws {
            region = params.aws_region
        }
        workDir = params.s3_work_dir
    }
}

// ── Container engine (Docker by default) ─────────────────────────────────────
docker {
    enabled    = true
    runOptions = '-u $(id -u):$(id -g)'
}
